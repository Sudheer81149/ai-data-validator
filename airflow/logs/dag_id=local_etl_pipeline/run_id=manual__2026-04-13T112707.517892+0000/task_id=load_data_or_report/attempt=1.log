{"timestamp":"2026-04-13T11:28:23.159690Z","level":"info","event":"def _convert_date(val):","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.159933Z","level":"info","event":"    if isinstance(val, str):","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.160155Z","level":"info","event":"        val = val.strip()","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.160354Z","level":"info","event":"        if not val or val.lower() in ('null', 'none', 'nan'):","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.160548Z","level":"info","event":"            return val","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.160741Z","level":"info","event":"        for fmt in ('%Y/%m/%d', '%d/%m/%Y', '%Y-%m-%d', '%d-%m-%Y'):","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.160995Z","level":"info","event":"            try:","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.161193Z","level":"info","event":"                parsed = datetime.strptime(val, fmt)","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.161388Z","level":"info","event":"                return parsed.strftime('%d/%m/%Y')","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.161582Z","level":"info","event":"            except ValueError:","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.161774Z","level":"info","event":"                continue","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.161980Z","level":"info","event":"        return val  # unchanged if unparseable","logger":"task.stdout"}
{"timestamp":"2026-04-13T11:28:23.162183Z","level":"info","event":"    return val","logger":"task.stdout"}
