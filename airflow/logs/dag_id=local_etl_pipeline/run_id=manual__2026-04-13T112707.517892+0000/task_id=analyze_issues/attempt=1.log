)\\n                return parsed.strftime('%d/%m/%Y')\\n            except ValueError:\\n                continue\\n        return val  # unchanged if unparseable\\n    return val\\n\\ndf['date'] = df['date'].apply(_convert_date)\\n\\n# ----- Name composition -----\\ndef _build_full_name(row):\\n    first = str(row.get('first_name', '')).strip()\\n    last  = str(row.get('last_name', '')).strip()\\n    if first.lower() in ('null', 'none', 'nan', '') and last.lower() in ('null', 'none', 'nan', ''):\\n        return None\\n    return f'{first} {last}'.strip()\\n\\ndf['full_name'] = df.apply(_build_full_name, axis=1)\\n\\n# Optional: flag records that still need review\\ndf['date_issue_flag'] = df['date'].apply(lambda x: x if isinstance(x, str) and not any(c.isdigit() for c in x) else None)\\ndf['name_issue_flag'] = df['full_name'].isnull()\\n\", \"# If you prefer to drop records that cannot be resolved instead of flagging:\\n# df = df[df['full_name'].notnull()].copy()\\n# df = df[~df['date'].str.contains('invalid-date', na=False)].copy()\\n\"], 'next_steps': ['1. Integrate the provided functions into your existing ETL script (e.g., within the transformation stage).', '2. Run the script on a subset of the data to verify that date values are now in dd/mm/yyyy format and that full_name is populated where possible.', '3. Examine the flag columns (`date_issue_flag`, `name_issue_flag`) to identify records that still require manual review or alternative handling.', '4. If business policy dictates dropping unresolved records, uncomment the filtering lines in the second code block and re‑run the pipeline.', '5. Add unit tests for `_convert_date` and `_build_full_name` to ensure future data changes do not reintroduce these issues.']}","logger":"airflow.task.operators.airflow.providers.standard.operators.python.PythonOperator","filename":"python.py","lineno":229}
